generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId                            String                     @id @default(cuid())
  username                          String                     @unique
  email                             String                     @unique
  password                          String
  salt                              String
  role                              Roles
  createdAt                         DateTime                   @default(now())
  updatedAt                         DateTime                   @updatedAt
  isDisabled                        Boolean                    @default(false)
  employee                          Employee?
  // Audit backlinks for contributions
  createdContributions              EmployeeContribution[]     @relation("EmployeeContributionCreatedBy")
  updatedContributions              EmployeeContribution[]     @relation("EmployeeContributionUpdatedBy")
  // Users who supervise employees
  supervisedEmployees               Employee[]                 @relation("EmployeeSupervisorUser")
  draftedViolations                 EmployeeViolation[]        @relation("EmployeeViolationDraftedBy")
  reviewedViolations                EmployeeViolation[]        @relation("EmployeeViolationReviewedBy")
  createdViolationResets            EmployeeViolationReset[]   @relation("EmployeeViolationResetCreatedBy")
  createdViolationAutoResetPolicies ViolationAutoResetPolicy[] @relation("ViolationAutoResetPolicyCreatedBy")
  createdEmployeeTypes              EmployeeType[]             @relation("EmployeeTypeCreatedBy")
  createdPayrolls                   Payroll[]                  @relation("PayrollCreatedBy")
  managerReviewedPayrolls           Payroll[]                  @relation("PayrollManagerReviewedBy")
  gmReviewedPayrolls                Payroll[]                  @relation("PayrollGmReviewedBy")
  releasedPayrolls                  Payroll[]                  @relation("PayrollReleasedBy")
  createdPayrollEmployees           PayrollEmployee[]          @relation("PayrollEmployeeCreatedBy")
  updatedPayrollEmployees           PayrollEmployee[]          @relation("PayrollEmployeeUpdatedBy")
  createdPayrollEarnings            PayrollEarning[]           @relation("PayrollEarningCreatedBy")
  createdPayrollDeductions          PayrollDeduction[]         @relation("PayrollDeductionCreatedBy")
  createdDeductionTypes             DeductionType[]            @relation("DeductionTypeCreatedBy")
  updatedDeductionTypes             DeductionType[]            @relation("DeductionTypeUpdatedBy")
  assignedEmployeeDeductions        EmployeeDeductionAssignment[] @relation("EmployeeDeductionAssignmentAssignedBy")
  updatedEmployeeDeductions         EmployeeDeductionAssignment[] @relation("EmployeeDeductionAssignmentUpdatedBy")

  @@index([createdAt])
  @@index([role, username])
  @@index([isDisabled, username])
}

model Employee {
  employeeId                   String                @id @default(cuid())
  employeeCode                 String                @unique
  firstName                    String
  lastName                     String
  middleName                   String?
  suffix                       SUFFIX?
  sex                          GENDER
  civilStatus                  CIVIL_STATUS
  nationality                  String?
  birthdate                    DateTime
  address                      String?
  city                         String?
  state                        String?
  postalCode                   String?
  country                      String?
  img                          String?
  startDate                    DateTime
  isEnded                      Boolean?              @default(false)
  endDate                      DateTime?
  employmentStatus             EMPLOYMENT_STATUS
  currentStatus                CURRENT_STATUS
  email                        String?
  phone                        String?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  emergencyContactEmail        String?
  // Daily base pay used for pro-rated attendance pay (e.g., 450.00 per paid day).
  dailyRate                    Decimal?              @db.Decimal(10, 2)
  description                  String?
  isArchived                   Boolean               @default(false)
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  userId                       String?               @unique
  user                         User?                 @relation(fields: [userId], references: [userId])
  departmentId                 String?
  positionId                   String?
  supervisorUserId             String?
  employeeTypeId               String?
  department                   Department?           @relation(fields: [departmentId], references: [departmentId])
  position                     Position?             @relation(fields: [positionId], references: [positionId])
  supervisorUser               User?                 @relation("EmployeeSupervisorUser", fields: [supervisorUserId], references: [userId])
  employeeType                 EmployeeType?         @relation(fields: [employeeTypeId], references: [employeeTypeId])
  governmentId                 GovernmentId?         @relation("EmployeeGovernmentId")
  contribution                 EmployeeContribution?
  rateHistory                  EmployeeRateHistory[]

  // Scheduling links
  patternAssignments         EmployeePatternAssignment[]
  shiftOverrides             EmployeeShiftOverride[]
  attendances                Attendance[]
  punches                    Punch[]
  employeeViolations         EmployeeViolation[]
  violationResets            EmployeeViolationReset[]
  violationAutoResetPolicies ViolationAutoResetPolicy[]
  payrollEmployees           PayrollEmployee[]
  deductionAssignments       EmployeeDeductionAssignment[]

  @@index([isArchived, employeeCode])
  @@index([departmentId])
  @@index([positionId])
  @@index([employeeTypeId])
}

model EmployeeType {
  employeeTypeId  String     @id @default(cuid())
  name            String     @unique
  description     String?
  isActive        Boolean    @default(true)
  createdByUserId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdBy       User?      @relation("EmployeeTypeCreatedBy", fields: [createdByUserId], references: [userId])
  employees       Employee[]

  @@index([isActive, name])
}

// ======== ORG STRUCTURE ========= //

/// Department catalog (simple name/description, soft active flag).
model Department {
  departmentId String     @id @default(cuid())
  name         String     @unique
  description  String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  positions    Position[]
  employees    Employee[]

  @@index([isActive, name])
}

/// Positions (job titles) linked to a department.
model Position {
  positionId   String   @id @default(cuid())
  name         String
  description  String?
  isActive     Boolean  @default(true)
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [departmentId])
  employees  Employee[]

  @@unique([name, departmentId])
  @@index([isActive, departmentId, name])
}

// ======== EMPLOYEE CONTRIBUTION ========= //
model GovernmentId {
  governmentId     String   @id @default(cuid())
  sssNumber        String?
  philHealthNumber String?
  tinNumber        String?
  pagIbigNumber    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  employeeId       String   @unique
  employee         Employee @relation("EmployeeGovernmentId", fields: [employeeId], references: [employeeId])
}

model EmployeeContribution {
  id                  String   @id @default(cuid())
  employeeId          String   @unique
  employee            Employee @relation(fields: [employeeId], references: [employeeId])
  sssEe               Decimal  @default(0)
  sssEr               Decimal  @default(0)
  isSssActive         Boolean  @default(true)
  philHealthEe        Decimal  @default(0)
  philHealthEr        Decimal  @default(0)
  isPhilHealthActive  Boolean  @default(true)
  pagIbigEe           Decimal  @default(0)
  pagIbigEr           Decimal  @default(0)
  isPagIbigActive     Boolean  @default(true)
  withholdingEe       Decimal  @default(0)
  withholdingEr       Decimal  @default(0)
  isWithholdingActive Boolean  @default(true)
  effectiveDate       DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById         String?
  updatedById         String?
  createdBy           User?    @relation("EmployeeContributionCreatedBy", fields: [createdById], references: [userId])
  updatedBy           User?    @relation("EmployeeContributionUpdatedBy", fields: [updatedById], references: [userId])
}

model EmployeeRateHistory {
  id            String   @id @default(cuid())
  employeeId    String
  dailyRate     Decimal? @db.Decimal(10, 2)
  effectiveFrom DateTime @default(now())
  reason        String?
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@unique([employeeId, effectiveFrom])
  @@index([effectiveFrom])
}

// ======== SCHEDULE AND SHIFTS ========= //

/// A reusable shift template. Keep it small and only add more fields once needed.
model Shift {
  id                 Int      @id @default(autoincrement())
  code               String   @unique
  name               String
  startMinutes       Int // minutes since midnight (e.g., 9:00 AM -> 540)
  endMinutes         Int // minutes since midnight (e.g., 6:00 PM -> 1080)
  spansMidnight      Boolean  @default(false) // true when end wraps past midnight
  breakStartMinutes  Int?
  breakEndMinutes    Int?
  breakMinutesUnpaid Int      @default(0)
  paidHoursPerDay    Decimal  @db.Decimal(5, 2) // e.g., 8.00
  isActive           Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations to weekly patterns per day
  weeklyPatternsSun WeeklyPattern[] @relation("wp_sun")
  weeklyPatternsMon WeeklyPattern[] @relation("wp_mon")
  weeklyPatternsTue WeeklyPattern[] @relation("wp_tue")
  weeklyPatternsWed WeeklyPattern[] @relation("wp_wed")
  weeklyPatternsThu WeeklyPattern[] @relation("wp_thu")
  weeklyPatternsFri WeeklyPattern[] @relation("wp_fri")
  weeklyPatternsSat WeeklyPattern[] @relation("wp_sat")

  // Usage
  overrides   EmployeeShiftOverride[]
  attendances Attendance[]            @relation("attendance_expected_shift")

  @@index([name])
}

/// Weekly pattern that selects one shift per weekday; null means rest day.
model WeeklyPattern {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  sunShiftId Int?
  monShiftId Int?
  tueShiftId Int?
  wedShiftId Int?
  thuShiftId Int?
  friShiftId Int?
  satShiftId Int?

  sunShift Shift? @relation("wp_sun", fields: [sunShiftId], references: [id])
  monShift Shift? @relation("wp_mon", fields: [monShiftId], references: [id])
  tueShift Shift? @relation("wp_tue", fields: [tueShiftId], references: [id])
  wedShift Shift? @relation("wp_wed", fields: [wedShiftId], references: [id])
  thuShift Shift? @relation("wp_thu", fields: [thuShiftId], references: [id])
  friShift Shift? @relation("wp_fri", fields: [friShiftId], references: [id])
  satShift Shift? @relation("wp_sat", fields: [satShiftId], references: [id])

  assignments EmployeePatternAssignment[]
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@index([name])
}

/// Assigns a weekly pattern to an employee starting on a date.
model EmployeePatternAssignment {
  id                 String   @id @default(cuid())
  employeeId         String
  effectiveDate      DateTime // changeover date; latest <= target date applies
  patternId          String
  // Immutable snapshot of weekday shift IDs at assignment time.
  sunShiftIdSnapshot Int?
  monShiftIdSnapshot Int?
  tueShiftIdSnapshot Int?
  wedShiftIdSnapshot Int?
  thuShiftIdSnapshot Int?
  friShiftIdSnapshot Int?
  satShiftIdSnapshot Int?
  reason             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee Employee      @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  pattern  WeeklyPattern @relation(fields: [patternId], references: [id])

  @@index([employeeId, effectiveDate])
}

/// One-day exception that replaces the pattern-based shift.
model EmployeeShiftOverride {
  id         String   @id @default(cuid())
  employeeId String
  workDate   DateTime // date anchor (use start day for overnight)
  shiftId    Int? // null = mark as rest day
  source     String // "MANUAL", "APPROVED_REQUEST"
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  shift    Shift?   @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, workDate])
  @@index([workDate])
}

/// Daily attendance snapshot; expected times come from pattern/override.
model Attendance {
  id         String            @id @default(cuid())
  employeeId String
  workDate   DateTime
  status     ATTENDANCE_STATUS

  // Expected
  expectedShiftId       Int?
  scheduledStartMinutes Int?
  scheduledEndMinutes   Int?
  paidHoursPerDay       Decimal? @db.Decimal(5, 2)

  // Actuals
  actualInAt           DateTime?
  actualOutAt          DateTime?
  workedMinutes        Int?
  breakMinutes         Int       @default(0)
  // Break minutes deducted for payroll (policy-driven, e.g. max(scheduled, actual)).
  deductedBreakMinutes Int       @default(0)
  // Net payable minutes after deducted break.
  netWorkedMinutes     Int?
  breakCount           Int       @default(0)

  // Variances
  lateMinutes             Int @default(0)
  undertimeMinutes        Int @default(0)
  overtimeMinutesRaw      Int @default(0)
  overtimeMinutesApproved Int @default(0)
  nightMinutes            Int @default(0)

  // Posting/lock
  isLocked          Boolean @default(false)
  payrollPeriodId   String?
  payrollEmployeeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee        Employee         @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  expectedShift   Shift?           @relation("attendance_expected_shift", fields: [expectedShiftId], references: [id])
  payroll         Payroll?         @relation("PayrollAttendanceRows", fields: [payrollPeriodId], references: [payrollId], onDelete: SetNull)
  payrollEmployee PayrollEmployee? @relation("PayrollEmployeeAttendanceRows", fields: [payrollEmployeeId], references: [id], onDelete: SetNull)
  punches         Punch[]

  @@unique([employeeId, workDate])
  @@index([employeeId, workDate])
  @@index([workDate])
  @@index([status, workDate])
  @@index([isLocked, workDate])
  @@index([payrollPeriodId])
  @@index([payrollEmployeeId])
}

/// Raw punch events; use them to recompute Attendance in real time.
model Punch {
  id           String     @id @default(cuid())
  employeeId   String
  attendanceId String?
  punchTime    DateTime
  punchType    PUNCH_TYPE
  source       String? // e.g., "BIOMETRIC", "WEB"
  deviceId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  employee   Employee    @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  attendance Attendance? @relation(fields: [attendanceId], references: [id])

  @@index([employeeId, punchTime])
  @@index([punchTime])
  @@index([attendanceId])
}

model EmployeeViolation {
  id                   String                  @id @default(cuid())
  employeeId           String
  violationId          String
  violationDate        DateTime
  strikePointsSnapshot Int                     @default(1)
  status               EmployeeViolationStatus @default(DRAFT)
  draftedById          String?
  submittedAt          DateTime?
  reviewedById         String?
  reviewedAt           DateTime?
  reviewRemarks        String?
  isAcknowledged       Boolean                 @default(false)
  acknowledgedAt       DateTime?
  remarks              String?
  isCountedForStrike   Boolean                 @default(true)
  voidedAt             DateTime?
  voidReason           String?
  createdAt            DateTime                @default(now())

  violation  Violation @relation(fields: [violationId], references: [violationId], onDelete: Cascade)
  employee   Employee  @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  draftedBy  User?     @relation("EmployeeViolationDraftedBy", fields: [draftedById], references: [userId])
  reviewedBy User?     @relation("EmployeeViolationReviewedBy", fields: [reviewedById], references: [userId])

  @@index([employeeId, violationDate])
  @@index([violationId])
  @@index([status, violationDate])
  @@index([draftedById])
  @@index([reviewedById])
  @@index([isCountedForStrike, voidedAt])
}

model Violation {
  violationId           String   @id @default(cuid())
  name                  String
  description           String
  defaultStrikePoints   Int      @default(1)
  // Per employee cap for counted strikes of this violation type.
  maxStrikesPerEmployee Int      @default(3)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  employeeViolations EmployeeViolation[]
  violationResets    EmployeeViolationReset[]
  autoResetPolicies  ViolationAutoResetPolicy[]

  @@index([name])
}

model EmployeeViolationReset {
  id              String   @id @default(cuid())
  employeeId      String
  violationId     String?
  effectiveFrom   DateTime
  reason          String
  createdByUserId String?
  autoPolicyId    String?
  createdAt       DateTime @default(now())

  employee   Employee                  @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  violation  Violation?                @relation(fields: [violationId], references: [violationId], onDelete: Cascade)
  createdBy  User?                     @relation("EmployeeViolationResetCreatedBy", fields: [createdByUserId], references: [userId])
  autoPolicy ViolationAutoResetPolicy? @relation("ViolationAutoResetPolicyResets", fields: [autoPolicyId], references: [id], onDelete: SetNull)

  @@index([employeeId, effectiveFrom])
  @@index([employeeId, violationId, effectiveFrom])
  @@index([createdAt])
}

model ViolationAutoResetPolicy {
  id                    String                  @id @default(cuid())
  name                  String?
  frequency             ViolationResetFrequency
  dayOfMonth            Int                     @default(1)
  monthOfYear           Int?
  effectiveFrom         DateTime                @default(now())
  nextRunAt             DateTime
  lastRunAt             DateTime?
  reasonTemplate        String?
  appliesToAllEmployees Boolean                 @default(true)
  employeeId            String?
  violationId           String?
  isActive              Boolean                 @default(true)
  createdByUserId       String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  employee  Employee?                @relation(fields: [employeeId], references: [employeeId], onDelete: SetNull)
  violation Violation?               @relation(fields: [violationId], references: [violationId], onDelete: SetNull)
  createdBy User?                    @relation("ViolationAutoResetPolicyCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  resets    EmployeeViolationReset[] @relation("ViolationAutoResetPolicyResets")

  @@index([isActive, nextRunAt])
  @@index([employeeId])
  @@index([violationId])
  @@index([frequency, dayOfMonth, monthOfYear])
}

model DeductionType {
  id            String             @id @default(cuid())
  code          String             @unique
  name          String
  description   String?
  // FIXED = flat amount per trigger; PERCENT = percentage-based deduction.
  amountMode    DeductionAmountMode
  // ONE_TIME, every payroll, or recurring installment mode.
  frequency     DeductionFrequency @default(PER_PAYROLL)
  // Defaults used when assignment does not override value.
  defaultAmount Decimal?           @db.Decimal(12, 2)
  defaultPercent Decimal?          @db.Decimal(5, 2)
  isActive      Boolean            @default(true)
  createdByUserId String?
  updatedByUserId String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  assignments      EmployeeDeductionAssignment[]
  payrollDeductions PayrollDeduction[]
  createdBy        User?            @relation("DeductionTypeCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  updatedBy        User?            @relation("DeductionTypeUpdatedBy", fields: [updatedByUserId], references: [userId], onDelete: SetNull)

  @@index([isActive, name])
}

model EmployeeDeductionAssignment {
  id                   String                           @id @default(cuid())
  employeeId           String
  deductionTypeId      String
  // Assignment is applied only when payroll period is within this range.
  effectiveFrom        DateTime
  effectiveTo          DateTime?
  // Optional per-employee override over DeductionType defaults.
  amountOverride       Decimal?                         @db.Decimal(12, 2)
  percentOverride      Decimal?                         @db.Decimal(5, 2)
  // Installment fields support cash advance/loan style repayments.
  installmentTotal     Decimal?                         @db.Decimal(12, 2)
  installmentPerPayroll Decimal?                        @db.Decimal(12, 2)
  remainingBalance     Decimal?                         @db.Decimal(12, 2)
  // ACTIVE participates in payroll; PAUSED/CANCELLED are skipped; COMPLETED is fully settled.
  status               EmployeeDeductionAssignmentStatus @default(ACTIVE)
  reason               String?
  assignedByUserId     String?
  updatedByUserId      String?
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt

  employee         Employee         @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  deductionType    DeductionType    @relation(fields: [deductionTypeId], references: [id], onDelete: Restrict)
  payrollDeductions PayrollDeduction[]
  assignedBy       User?            @relation("EmployeeDeductionAssignmentAssignedBy", fields: [assignedByUserId], references: [userId], onDelete: SetNull)
  updatedBy        User?            @relation("EmployeeDeductionAssignmentUpdatedBy", fields: [updatedByUserId], references: [userId], onDelete: SetNull)

  @@unique([employeeId, deductionTypeId, effectiveFrom])
  @@index([employeeId, status, effectiveFrom])
  @@index([deductionTypeId, status])
}

//PAYROLL SCHEMA

model Payroll {
  payrollId                String                @id @default(cuid())
  payrollPeriodStart       DateTime
  payrollPeriodEnd         DateTime
  payrollType              PayrollType
  status                   PayrollStatus         @default(DRAFT)
  managerDecision          PayrollReviewDecision @default(PENDING)
  gmDecision               PayrollReviewDecision @default(PENDING)
  generatedAt              DateTime              @default(now())
  managerReviewedAt        DateTime?
  gmReviewedAt             DateTime?
  releasedAt               DateTime?
  managerReviewRemarks     String?
  gmReviewRemarks          String?
  notes                    String?
  createdByUserId          String?
  managerReviewedByUserId  String?
  gmReviewedByUserId       String?
  releasedByUserId         String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  payrollEmployees PayrollEmployee[]
  attendanceRows   Attendance[]    @relation("PayrollAttendanceRows")
  createdBy        User?           @relation("PayrollCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  managerReviewedBy User?          @relation("PayrollManagerReviewedBy", fields: [managerReviewedByUserId], references: [userId], onDelete: SetNull)
  gmReviewedBy     User?           @relation("PayrollGmReviewedBy", fields: [gmReviewedByUserId], references: [userId], onDelete: SetNull)
  releasedBy       User?           @relation("PayrollReleasedBy", fields: [releasedByUserId], references: [userId], onDelete: SetNull)

  @@index([status, payrollPeriodStart, payrollPeriodEnd])
  @@index([payrollType, payrollPeriodStart])
  @@index([payrollPeriodStart, payrollPeriodEnd, payrollType])
  @@index([managerDecision, gmDecision, status])
}

model PayrollEmployee {
  id                    String                @id @default(cuid())
  payrollId             String
  employeeId            String
  attendanceStart       DateTime
  attendanceEnd         DateTime
  daysPresent           Int                   @default(0)
  daysAbsent            Int                   @default(0)
  daysLate              Int                   @default(0)
  minutesWorked         Int                   @default(0)
  minutesNetWorked      Int                   @default(0)
  minutesOvertime       Int                   @default(0)
  minutesUndertime      Int                   @default(0)
  dailyRateSnapshot     Decimal?              @db.Decimal(10, 2)
  ratePerMinuteSnapshot Decimal?              @db.Decimal(12, 6)
  grossPay              Decimal               @default(0) @db.Decimal(12, 2)
  totalEarnings         Decimal               @default(0) @db.Decimal(12, 2)
  totalDeductions       Decimal               @default(0) @db.Decimal(12, 2)
  netPay                Decimal               @default(0) @db.Decimal(12, 2)
  status                PayrollEmployeeStatus @default(DRAFT)
  notes                 String?
  createdByUserId       String?
  updatedByUserId       String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  payroll        Payroll            @relation(fields: [payrollId], references: [payrollId], onDelete: Cascade)
  employee       Employee           @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)
  earnings       PayrollEarning[]
  deductions     PayrollDeduction[]
  attendanceRows Attendance[]       @relation("PayrollEmployeeAttendanceRows")
  createdBy      User?              @relation("PayrollEmployeeCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  updatedBy      User?              @relation("PayrollEmployeeUpdatedBy", fields: [updatedByUserId], references: [userId], onDelete: SetNull)

  @@unique([payrollId, employeeId])
  @@index([employeeId, payrollId])
  @@index([status, payrollId])
}

model PayrollEarning {
  id                String               @id @default(cuid())
  payrollEmployeeId String
  earningType       PayrollEarningType
  amount            Decimal              @db.Decimal(12, 2)
  minutes           Int?
  rateSnapshot      Decimal?             @db.Decimal(12, 6)
  source            PayrollLineSource    @default(SYSTEM)
  isManual          Boolean              @default(false)
  referenceType     PayrollReferenceType?
  referenceId       String?
  remarks           String?
  isVoided          Boolean              @default(false)
  voidedAt          DateTime?
  voidReason        String?
  createdByUserId   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  payrollEmployee PayrollEmployee @relation(fields: [payrollEmployeeId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("PayrollEarningCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)

  @@index([payrollEmployeeId, earningType])
  @@index([source])
  @@index([referenceType, referenceId])
}

model PayrollDeduction {
  id                String               @id @default(cuid())
  payrollEmployeeId String
  // Keep enum for core/system deductions; use OTHER for custom catalog-driven types.
  deductionType     PayrollDeductionType @default(OTHER)
  // Optional link to dynamic DeductionType created by GM.
  deductionTypeId   String?
  // Optional link back to employee assignment that produced this line.
  assignmentId      String?
  // Snapshot label shown in payslip even if master type changes later.
  deductionCodeSnapshot String?
  deductionNameSnapshot String?
  amount            Decimal              @db.Decimal(12, 2)
  minutes           Int?
  rateSnapshot      Decimal?             @db.Decimal(12, 6)
  source            PayrollLineSource    @default(SYSTEM)
  isManual          Boolean              @default(false)
  referenceType     PayrollReferenceType?
  referenceId       String?
  remarks           String?
  isVoided          Boolean              @default(false)
  voidedAt          DateTime?
  voidReason        String?
  createdByUserId   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  payrollEmployee PayrollEmployee @relation(fields: [payrollEmployeeId], references: [id], onDelete: Cascade)
  deductionTypeDef DeductionType? @relation(fields: [deductionTypeId], references: [id], onDelete: SetNull)
  assignment      EmployeeDeductionAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  createdBy       User?           @relation("PayrollDeductionCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)

  @@index([payrollEmployeeId, deductionType])
  @@index([deductionTypeId])
  @@index([assignmentId])
  @@index([source])
  @@index([referenceType, referenceId])
}

